# =============================================================================
# Ragent — Environment Variables
# =============================================================================
# Copy to .env and fill in real values for your deployment.
# =============================================================================

# ---- Server ----
PORT=8090

# ---- Auth ----
INTERNAL_API_TOKEN=change-me
AUTH_SESSION_SECRET=change-me

# ---- Storage ----
# GO_INGESTION_STORE=memory        # memory | sqlite | mysql
# GO_INDEX_STORE=json-file         # json-file | qdrant

# ---- AI / Retrieval ----
# GO_EMBEDDING_ADAPTER=deterministic   # deterministic | openai
# GO_PARSER_ADAPTER=text-parser        # text-parser | tika
# GO_RETRIEVAL_SOURCE=indexed-store    # indexed-store | local-corpus
# GO_RETRIEVAL_MODE=hybrid             # hybrid | vector | keyword
# GO_RETRIEVAL_FALLBACK_ENABLED=true
# BGE_RERANKER_URL=http://localhost:8080/rerank

# ---- Qdrant (required when GO_INDEX_STORE=qdrant) ----
# QDRANT_URL=http://localhost:6334
# QDRANT_API_KEY=

# ---- Ingestion Runner ----
# GO_INGESTION_RUNNER_ENABLED=true
# GO_INGESTION_WORKER_ID=
# GO_INGESTION_RUNNER_LEASE=30s
# GO_INGESTION_RUNNER_INTERVAL=2s
# GO_INGESTION_RUNNER_LIMIT=4
